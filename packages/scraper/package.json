{
  "name": "@pokopia-wiki/scraper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./src/*.ts"
  },
  "scripts": {
    "scrape": "tsx --env-file-if-exists=../../.env src/index.ts",
    "check:robots": "tsx --env-file-if-exists=../../.env scripts/check-robots.ts",
    "check:access": "tsx --env-file-if-exists=../../.env scripts/check-access.ts",
    "check:patchright": "tsx --env-file-if-exists=../../.env scripts/check-patchright.ts",
    "check:network": "tsx --env-file-if-exists=../../.env scripts/check-network.ts",
    "notifier:test": "tsx --env-file-if-exists=../../.env scripts/notifier-test.ts",
    "status": "tsx --env-file-if-exists=../../.env scripts/status.ts",
    "validate": "tsx --env-file-if-exists=../../.env scripts/validate.ts",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "lint": "oxlint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@pokopia-wiki/shared": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
