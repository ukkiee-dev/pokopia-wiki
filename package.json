{
  "name": "pokopia-wiki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r --parallel build",
    "test": "pnpm -r --parallel test:run",
    "lint": "pnpm -r --parallel lint",
    "type-check": "pnpm -r --parallel type-check",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
