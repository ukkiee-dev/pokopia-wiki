{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",

  // 한 줄 최대 폭 (기본 100 → 120으로 완화)
  "printWidth": 120,

  // 쌍따옴표 대신 홑따옴표
  "singleQuote": true,

  // import 구문 자동 정렬 (builtin → external → [internal, subpath] → [parent, sibling, index] → style → unknown)
  // 그룹 내부는 알파벳 오름차순, 그룹 간 빈 줄 삽입
  "sortImports": true,

  // package.json 키 정렬 (기본 true지만 명시)
  "sortPackageJson": true,

  // 포맷팅 제외 — 배포/인프라 파일은 손대지 않음
  "ignorePatterns": [
    ".github/**", // GitHub Actions workflow
    "**/.app-config.yml", // ArgoCD 연동용 앱 설정 (모노레포 이동 후 packages/api에 위치)
    "pnpm-lock.yaml", // pnpm 생성물
    "**/Dockerfile",
    ".dockerignore",
    "**/*.md", // .vscode/settings.json에서 markdown은 prettier 담당으로 위임
    ".claude/**", // 에이전트/스킬 정의 (md + 보조 파일, 수동 관리)
    "docs/**", // 기획/로드맵 문서 (수동 관리)
    "**/dist/**",
    "**/node_modules/**",
    "packages/shared/src/prisma-client/**", // Prisma 생성물
  ],
}
