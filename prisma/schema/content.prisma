// Pokopia Wiki — §2.15 커스터마이징 + §2.16 CD + §2.19 식물 + §2.21 이벤트 + §2.22 미니게임 + §2.23 Mosslax
//
// 모델: CustomizationItem, CustomizationItemI18n,
//       Cd, CdI18n, SourceGame, SourceGameI18n, CdLocation,
//       Plant, PlantI18n, PlantVariant,
//       Event, EventI18n, EventPokemon, EventHabitat, EventItem,
//       StampCard, StampReward, JumpropeTier, HideAndSneakReward,
//       MosslaxBoost, MosslaxBoostI18n
// ENUM: CustomizationCategory, PlantType, JumpropeRewardType, HideAndSneakRewardType
//
// 참고: MosslaxBoost.flavor는 item.prisma의 FlavorType을 참조.

// ─── §2.15 커스터마이징 ───

model CustomizationItem {
  id               Int                   @id @default(autoincrement())
  category         CustomizationCategory
  unlockMethod     String                @map("unlock_method")
  unlockLocationId Int?                  @map("unlock_location_id")

  sourceSlug  String   @unique @map("source_slug")
  sourceUrl   String   @map("source_url")
  scrapedAt   DateTime @map("scraped_at")
  contentHash String   @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  unlockLocation Location?               @relation(fields: [unlockLocationId], references: [id], onDelete: SetNull)
  translations   CustomizationItemI18n[]

  @@index([category])
  @@map("customization_item")
}

model CustomizationItemI18n {
  customizationItemId Int        @map("customization_item_id")
  locale              String
  name                String
  description         String?
  source              I18nSource
  verified            Boolean    @default(false)
  verifiedAt          DateTime?  @map("verified_at")
  verifiedBy          String?    @map("verified_by")

  customizationItem CustomizationItem @relation(fields: [customizationItemId], references: [id], onDelete: Cascade)

  @@id([customizationItemId, locale])
  @@map("customization_item_i18n")
}

// ─── §2.16 CD / 음악 ───

model Cd {
  id           Int @id @default(autoincrement())
  sourceGameId Int @map("source_game_id")

  sourceSlug  String   @unique @map("source_slug")
  sourceUrl   String   @map("source_url")
  scrapedAt   DateTime @map("scraped_at")
  contentHash String   @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sourceGame   SourceGame   @relation(fields: [sourceGameId], references: [id], onDelete: Restrict)
  translations CdI18n[]
  locations    CdLocation[]

  @@index([sourceGameId])
  @@map("cd")
}

model CdI18n {
  cdId        Int        @map("cd_id")
  locale      String
  name        String
  description String?
  source      I18nSource
  verified    Boolean    @default(false)
  verifiedAt  DateTime?  @map("verified_at")
  verifiedBy  String?    @map("verified_by")

  cd Cd @relation(fields: [cdId], references: [id], onDelete: Cascade)

  @@id([cdId, locale])
  @@map("cd_i18n")
}

model SourceGame {
  id         Int    @id @default(autoincrement())
  code       String @unique
  generation Int

  sourceSlug  String   @unique @map("source_slug")
  sourceUrl   String   @map("source_url")
  scrapedAt   DateTime @map("scraped_at")
  contentHash String   @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  translations SourceGameI18n[]
  cds          Cd[]

  @@map("source_game")
}

model SourceGameI18n {
  sourceGameId Int        @map("source_game_id")
  locale       String
  name         String
  description  String?
  source       I18nSource
  verified     Boolean    @default(false)
  verifiedAt   DateTime?  @map("verified_at")
  verifiedBy   String?    @map("verified_by")

  sourceGame SourceGame @relation(fields: [sourceGameId], references: [id], onDelete: Cascade)

  @@id([sourceGameId, locale])
  @@map("source_game_i18n")
}

model CdLocation {
  id         Int    @id @default(autoincrement())
  cdId       Int    @map("cd_id")
  locationId Int?   @map("location_id")
  method     String

  cd       Cd        @relation(fields: [cdId], references: [id], onDelete: Cascade)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([cdId])
  @@map("cd_location")
}

// ─── §2.19 꽃 & 채소 ───

model Plant {
  id                 Int       @id @default(autoincrement())
  type               PlantType
  growthDays         Int       @map("growth_days")
  growthDaysWithGrow Int       @map("growth_days_with_grow")
  requiresHydration  Boolean   @map("requires_hydration")

  sourceSlug  String   @unique @map("source_slug")
  sourceUrl   String   @map("source_url")
  scrapedAt   DateTime @map("scraped_at")
  contentHash String   @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  translations PlantI18n[]
  variants     PlantVariant[]

  @@index([type])
  @@map("plant")
}

model PlantI18n {
  plantId     Int        @map("plant_id")
  locale      String
  name        String
  description String?
  source      I18nSource
  verified    Boolean    @default(false)
  verifiedAt  DateTime?  @map("verified_at")
  verifiedBy  String?    @map("verified_by")

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@id([plantId, locale])
  @@map("plant_i18n")
}

model PlantVariant {
  id      Int    @id @default(autoincrement())
  plantId Int    @map("plant_id")
  color   String

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@index([plantId])
  @@map("plant_variant")
}

// ─── §2.21 이벤트 시스템 ───

model Event {
  id          Int       @id @default(autoincrement())
  startAt     DateTime? @map("start_at") @db.Date
  endAt       DateTime? @map("end_at") @db.Date
  isRecurring Boolean   @map("is_recurring")

  sourceSlug  String   @unique @map("source_slug")
  sourceUrl   String   @map("source_url")
  scrapedAt   DateTime @map("scraped_at")
  contentHash String   @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  translations EventI18n[]
  pokemon      EventPokemon[]
  habitats     EventHabitat[]
  items        EventItem[]

  @@map("event")
}

model EventI18n {
  eventId     Int        @map("event_id")
  locale      String
  name        String
  description String?
  source      I18nSource
  verified    Boolean    @default(false)
  verifiedAt  DateTime?  @map("verified_at")
  verifiedBy  String?    @map("verified_by")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([eventId, locale])
  @@map("event_i18n")
}

model EventPokemon {
  eventId   Int @map("event_id")
  pokemonId Int @map("pokemon_id")

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pokemon Pokemon @relation(fields: [pokemonId], references: [id], onDelete: Cascade)

  @@id([eventId, pokemonId])
  @@map("event_pokemon")
}

model EventHabitat {
  eventId   Int @map("event_id")
  habitatId Int @map("habitat_id")

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  habitat Habitat @relation(fields: [habitatId], references: [id], onDelete: Cascade)

  @@id([eventId, habitatId])
  @@map("event_habitat")
}

model EventItem {
  eventId Int @map("event_id")
  itemId  Int @map("item_id")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  item  Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([eventId, itemId])
  @@map("event_item")
}

// ─── §2.22 미니게임 & 주간 콘텐츠 ───

model StampCard {
  id       Int @id @default(autoincrement())
  weekGoal Int @map("week_goal")

  sourceSlug  String   @unique @map("source_slug")
  sourceUrl   String   @map("source_url")
  scrapedAt   DateTime @map("scraped_at")
  contentHash String   @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rewards StampReward[]

  @@map("stamp_card")
}

model StampReward {
  id             Int @id @default(autoincrement())
  cardId         Int @map("card_id")
  tier           Int
  requiredStamps Int @map("required_stamps")
  coinAmount     Int @map("coin_amount")

  sourceSlug  String   @unique @map("source_slug")
  sourceUrl   String   @map("source_url")
  scrapedAt   DateTime @map("scraped_at")
  contentHash String   @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  card StampCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, tier])
  @@map("stamp_reward")
}

model JumpropeTier {
  id            Int                @id @default(autoincrement())
  tier          Int                @unique
  requiredJumps Int                @map("required_jumps")
  rewardType    JumpropeRewardType @map("reward_type")
  rewardRefId   Int?               @map("reward_ref_id")

  sourceSlug  String   @unique @map("source_slug")
  sourceUrl   String   @map("source_url")
  scrapedAt   DateTime @map("scraped_at")
  contentHash String   @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("jumprope_tier")
}

model HideAndSneakReward {
  id          Int                    @id @default(autoincrement())
  condition   String
  rewardType  HideAndSneakRewardType @map("reward_type")
  rewardRefId Int                    @map("reward_ref_id")

  sourceSlug  String   @unique @map("source_slug")
  sourceUrl   String   @map("source_url")
  scrapedAt   DateTime @map("scraped_at")
  contentHash String   @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("hideandsneak_reward")
}

// ─── §2.23 Mosslax 부스트 ───

model MosslaxBoost {
  id     Int        @id @default(autoincrement())
  flavor FlavorType // None은 앱 레벨에서 배제 (SCHEMA §2.23은 Bitter/Dry/Sour/Spicy/Sweet 5값). FlavorType은 item.prisma에 정의.
  level  Int // 1~3

  sourceSlug  String   @unique @map("source_slug")
  sourceUrl   String   @map("source_url")
  scrapedAt   DateTime @map("scraped_at")
  contentHash String   @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  translations MosslaxBoostI18n[]

  @@unique([flavor, level])
  @@map("mosslax_boost")
}

model MosslaxBoostI18n {
  boostId     Int        @map("boost_id")
  locale      String
  name        String
  description String? // 효과 설명
  source      I18nSource
  verified    Boolean    @default(false)
  verifiedAt  DateTime?  @map("verified_at")
  verifiedBy  String?    @map("verified_by")

  boost MosslaxBoost @relation(fields: [boostId], references: [id], onDelete: Cascade)

  @@id([boostId, locale])
  @@map("mosslax_boost_i18n")
}

// ─── ENUMs ───

enum CustomizationCategory {
  Hair
  Outfit
  Top
  Pants
  Hat
  Bag
  Shoes
}

enum PlantType {
  BerryTree
  Wildflower
  SeashorFlower
  MountainFlower
  SkylandFlower
  DecorativeFlower
  Hedge
  Vegetable
}

enum JumpropeRewardType {
  item
  coin
}

enum HideAndSneakRewardType {
  item
  coin
}
