NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# CORS 허용 origin (쉼표 구분). 비우면 차단, *는 모두 허용.
CORS_ORIGIN=

# PostgreSQL (Phase 1~): scraper와 api가 @pokopia-wiki/shared의 Prisma Client로 공유.
# 로컬 개발: `docker compose -f docker-compose.local.yml up -d` 후 아래 값 그대로 사용.
# homelab 이관 시 Tailscale 또는 포트포워딩 connection string으로 교체.
DATABASE_URL="postgresql://pokopia:pokopia_local_dev@localhost:5432/pokopia?schema=public"

# === Scraper (Phase 3+) ===

# Telegram 알림 (Task 3.7 Notifier, CRAWLING_STRATEGY §13.3)
# 발급 절차:
#   1. @BotFather 에서 /newbot → 봇 이름 입력 → 토큰 복사
#   2. 생성된 봇에게 /start 전송
#   3. @userinfobot 또는 curl "https://api.telegram.org/bot<TOKEN>/getUpdates" 로 chat_id 조회
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Critical severity 이벤트만 별도 라우팅할 chat_id (비우면 TELEGRAM_CHAT_ID 로 폴백)
TELEGRAM_CHAT_ID_CRITICAL=

# false/미설정 시 Notifier는 console fallback 만 수행 (dev/CI 용).
# 프로덕션 실행 시 반드시 true.
NOTIFICATIONS_ENABLED=

# Scraper 전역 User-Agent (robots.txt 식별 + 소스 운영자에게 식별 가능하도록 연락처 포함).
# 예시: PokopiaScraperBot/1.0 (+your-email@domain.com)
SCRAPER_USER_AGENT=

# 이미지 저장 루트 (CRAWLING_STRATEGY §21). 미설정 시 ./data/images 사용.
IMAGE_ROOT=

# 외장 SSD 백업 마운트 포인트 (CRAWLING_STRATEGY §29.2). 미마운트 시 백업 job 스킵.
EXTERNAL_SSD_MOUNT=
